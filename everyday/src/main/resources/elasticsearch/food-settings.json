{
  "analysis": {
    "analyzer": {
      "korean_search": {
        "type": "custom",
        "tokenizer": "nori_tokenizer",
        "filter": ["lowercase", "nori_part_of_speech"]
      }
    },
    "tokenizer": {
      "nori_tokenizer": {
        "type": "nori_tokenizer",
        "decompound_mode": "mixed"
      }
    },
    "filter": {
      "nori_part_of_speech": {
        "type": "nori_part_of_speech",
        "stoptags": ["E","IC","J","MAG","MAJ","MM","UNKNOWN","SP","SSC","SSO","SC","SE","SF","SY"]
      }
    }
  }
}